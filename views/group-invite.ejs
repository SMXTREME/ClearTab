<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ClearTab — You've been invited</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0a; --surface: #111111; --surface-2: #161616;
      --border: #1e1e1e; --border-lit: #2a2a2a;
      --text: #e8e8e0; --muted: #8b8b76;
      --accent: #c8f060; --accent-dim: #8faa40; --accent-bg: rgba(200,240,96,.06);
      --danger: #ff5f5f; --positive: #60f0a8;
      --mono: 'DM Mono', monospace; --sans: 'Syne', sans-serif;
    }
    body {
      background: var(--bg); color: var(--text);
      font-family: var(--sans); min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      cursor: none; padding: 1.5rem;
    }
    a {
      cursor: none;
    }
    #cursor { position: fixed; width: 10px; height: 10px; background: var(--accent); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: width .15s, height .15s, opacity .15s; mix-blend-mode: difference; }
    body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E"); opacity: .02; pointer-events: none; z-index: 0; }

    .logo {
      position: fixed; top: 1.5rem; left: 2rem;
      font-family: var(--sans); font-weight: 800; font-size: 1.1rem;
      letter-spacing: -.02em; color: var(--text); text-decoration: none;
    }
    .logo span { color: var(--accent); }

    .card {
      width: 100%; max-width: 440px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
      position: relative; z-index: 1;
      animation: fadeUp .5s forwards;
      opacity: 0; transform: translateY(16px);
    }
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    .card-top {
      padding: 2rem 2rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 1.25rem;
    }
    .group-icon {
      width: 56px; height: 56px;
      background: var(--surface-2);
      border: 1px solid var(--border-lit);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem; flex-shrink: 0;
    }
    .group-info { }
    .invited-label {
      font-family: var(--mono); font-size: .68rem;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--accent); margin-bottom: .35rem;
    }
    .group-name { font-size: 1.3rem; font-weight: 800; letter-spacing: -.025em; }
    .group-meta { font-family: var(--mono); font-size: .7rem; color: var(--muted); margin-top: .25rem; }

    .card-body { padding: 1.5rem 2rem; }

    .inviter-row {
      display: flex; align-items: center; gap: .75rem;
      margin-bottom: 1.5rem;
    }
    .inviter-avatar { width: 28px; height: 28px; border-radius: 2px; overflow: hidden; background: var(--border-lit); flex-shrink: 0; }
    .inviter-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .inviter-text { font-family: var(--mono); font-size: .75rem; color: var(--muted); }
    .inviter-text b { color: var(--text); font-weight: 400; }

    .members-preview {
      display: flex; align-items: center; gap: .5rem;
      margin-bottom: 1.75rem;
    }
    .member-pip { width: 26px; height: 26px; border-radius: 2px; overflow: hidden; border: 1px solid var(--bg); margin-right: -6px; }
    .member-pip img { width: 100%; height: 100%; object-fit: cover; }
    .members-text { font-family: var(--mono); font-size: .7rem; color: var(--muted); margin-left: .85rem; }

    .card-actions { display: flex; flex-direction: column; gap: .6rem; }

    .btn-primary {
      width: 100%; background: var(--accent); color: var(--bg);
      border: none; font-family: var(--mono); font-size: .78rem;
      letter-spacing: .08em; text-transform: uppercase;
      padding: .85rem 1rem; border-radius: 2px; cursor: none;
      font-weight: 500; transition: background .2s, transform .1s;
      text-align: center; text-decoration: none; display: block;
    }
    .btn-primary:hover { background: var(--accent-dim); }
    .btn-primary:active { transform: scale(.98); }

    .btn-ghost {
      width: 100%; background: transparent; color: var(--muted);
      border: 1px solid var(--border-lit); font-family: var(--mono); font-size: .78rem;
      letter-spacing: .08em; text-transform: uppercase;
      padding: .85rem 1rem; border-radius: 2px; cursor: none;
      transition: border-color .2s, color .2s;
      text-align: center; text-decoration: none; display: block;
    }
    .btn-ghost:hover { border-color: var(--muted); color: var(--text); }

    .auth-note {
      font-family: var(--mono); font-size: .68rem;
      color: var(--muted); text-align: center;
      margin-top: 1rem; line-height: 1.6;
    }
    .auth-note a { color: var(--accent); text-decoration: none; }

    @media (max-width: 480px) {
      .logo { top: 1rem; left: 1rem; }
      .card-top { padding: 1.5rem; }
      .card-body { padding: 1.25rem 1.5rem; }
    }
  </style>
</head>
<body>
<div id="cursor"></div>

<a href="/" class="logo">ClearTab<span>.</span></a>

<div class="card">

  <div class="card-top">
    <div class="group-icon"><%= group.icon || '◈' %></div>
    <div class="group-info">
      <div class="invited-label">You're invited</div>
          <div class="group-name"><%= group.name %></div>
      <div class="group-meta"><%= group.members.length %> member<%= group.members.length !== 1 ? 's' : '' %> · <%= expenseCount %> expense<%= expenseCount !== 1 ? 's' : '' %></div>
    </div>
  </div>

  <div class="card-body">

    <!-- WHO INVITED -->
    <div class="inviter-row">
      <div class="inviter-avatar">
        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= group.createdBy.userName %>" alt="<%= group.createdBy.userName %>" />
      </div>
      <div class="inviter-text">Created by <b><%= group.createdBy.userName %></b></div>
    </div>

    <!-- MEMBER PIPS -->
    <div class="members-preview">
      <% group.members.slice(0, 5).forEach(m => { %>
        <div class="member-pip">
          <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= m.userName %>" alt="<%= m.userName %>" />
        </div>
      <% }) %>
      <span class="members-text"><%= group.members.length %> already in the group</span>
    </div>

    <!-- ACTIONS -->
    <div class="card-actions">
        <form action="/groups/<%= group._id %>/invite" method="POST">
          <button type="submit" class="btn-primary">Join Group →</button>
        </form>
        <a href="/dashboard" class="btn-ghost">Maybe later</a>
    </div>

  </div>
</div>

<script>
  const cur = document.getElementById('cursor');
  document.addEventListener('mousemove', e => { cur.style.left = e.clientX + 'px'; cur.style.top = e.clientY + 'px'; });
  document.querySelectorAll('button, a').forEach(el => {
    el.addEventListener('mouseenter', () => { cur.style.width = '22px'; cur.style.height = '22px'; cur.style.opacity = '.5'; });
    el.addEventListener('mouseleave', () => { cur.style.width = '10px'; cur.style.height = '10px'; cur.style.opacity = '1'; });
  });
</script>
</body>
</html>
