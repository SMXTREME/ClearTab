<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ClearTab — Add Expense</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0a; --surface: #111111; --surface-2: #161616;
      --border: #1e1e1e; --border-lit: #2a2a2a;
      --text: #e8e8e0; --muted: #8b8b76; --muted-2: #62625b;
      --accent: #c8f060; --accent-dim: #8faa40; --accent-bg: rgba(200,240,96,.06);
      --danger: #ff5f5f; --positive: #60f0a8;
      --mono: 'DM Mono', monospace; --sans: 'Syne', sans-serif;
      --sidebar-w: 240px;
    }
    html { scroll-behavior: smooth; }
    a {
      cursor: none;
    }
    body { background: var(--bg); color: var(--text); font-family: var(--sans); min-height: 100vh; display: flex; cursor: none; }
    #cursor { position: fixed; width: 10px; height: 10px; background: var(--accent); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: width .15s, height .15s, opacity .15s; mix-blend-mode: difference; }
    body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E"); opacity: .02; pointer-events: none; z-index: 0; }

    /* SIDEBAR */
    .sidebar { width: var(--sidebar-w); min-height: 100vh; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 50; }
    .sidebar-logo { padding: 1.5rem; border-bottom: 1px solid var(--border); font-family: var(--sans); font-weight: 800; font-size: 1.1rem; letter-spacing: -.02em; color: var(--text); text-decoration: none; display: block; }
    .sidebar-logo span { color: var(--accent); }
    .sidebar-nav { flex: 1; padding: 1rem 0; }
    .nav-section-label { font-family: var(--mono); font-size: .62rem; letter-spacing: .12em; text-transform: uppercase; color: var(--muted-2); padding: .75rem 1.5rem .4rem; }
    .nav-item { display: flex; align-items: center; gap: .75rem; padding: .6rem 1.5rem; font-family: var(--mono); font-size: .78rem; color: var(--muted); text-decoration: none; transition: color .2s, background .2s; position: relative; }
    .nav-item:hover { color: var(--text); background: var(--surface-2); }
    .nav-item.active { color: var(--accent); background: var(--accent-bg); }
    .nav-item.active::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--accent); }
    .nav-icon { font-size: .9rem; width: 16px; text-align: center; flex-shrink: 0; }
    .sidebar-user { padding: 1rem 1.5rem; border-top: 1px solid var(--border); display: flex; align-items: center; gap: .75rem; }
    .user-avatar { width: 32px; height: 32px; border-radius: 2px; background: var(--border-lit); overflow: hidden; flex-shrink: 0; }
    .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .user-name { font-size: .8rem; font-weight: 700; letter-spacing: -.01em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-email { font-family: var(--mono); font-size: .65rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* MAIN */
    .main { margin-left: var(--sidebar-w); flex: 1; min-height: 100vh; display: flex; flex-direction: column; position: relative; z-index: 1; }
    .topbar { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 2rem; border-bottom: 1px solid var(--border); background: rgba(10,10,10,.8); backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 40; }
    .topbar-left { display: flex; align-items: center; gap: 1rem; }
    .topbar-title { font-size: 1rem; font-weight: 700; letter-spacing: -.01em; }
    .hamburger { display: none; background: none; border: none; color: var(--text); font-size: 1.2rem; cursor: none; padding: .25rem; }
    .back-link { font-family: var(--mono); font-size: .72rem; color: var(--muted); text-decoration: none; letter-spacing: .04em; transition: color .2s; }
    .back-link:hover { color: var(--text); }

    /* CONTENT */
    .content { padding: 2rem; display: flex; justify-content: center; }

    /* FORM CARD */
    .form-card { width: 100%; max-width: 560px; display: flex; flex-direction: column; gap: 1rem; }

    .card-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 3px;
      overflow: hidden;
    }
    .card-block-header {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      font-family: var(--mono); font-size: .68rem;
      letter-spacing: .1em; text-transform: uppercase; color: var(--muted);
    }
    .card-block-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

    /* FIELDS */
    .field { display: flex; flex-direction: column; gap: .45rem; }
    .field-label { font-family: var(--mono); font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
    .field-input, .field-select {
      width: 100%; background: var(--bg); border: 1px solid var(--border-lit);
      color: var(--text); font-family: var(--mono); font-size: .9rem;
      padding: .75rem .9rem; border-radius: 2px; outline: none; transition: border-color .2s;
    }
    .field-input:focus, .field-select:focus { border-color: var(--accent); }
    .field-input::placeholder { color: var(--muted); }
    .field-select option { background: var(--surface); }

    /* AMOUNT ROW */
    .amount-row { position: relative; }
    .amount-prefix {
      position: absolute; left: .9rem; top: 50%; transform: translateY(-50%);
      font-family: var(--mono); font-size: .9rem; color: var(--muted);
      pointer-events: none;
    }
    .amount-row .field-input { padding-left: 1.6rem; font-size: 1.2rem; font-weight: 600; letter-spacing: -.01em; }

    /* SPLIT TYPE TOGGLE */
    .split-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: .4rem; }
    .split-opt { position: relative; }
    .split-opt input[type="radio"] { display: none; }
    .split-opt label {
      display: block; text-align: center;
      font-family: var(--mono); font-size: .72rem; letter-spacing: .06em; text-transform: uppercase;
      padding: .65rem 1rem; border-radius: 2px; cursor: none;
      border: 1px solid var(--border-lit); color: var(--muted);
      transition: border-color .2s, color .2s, background .2s;
    }
    .split-opt input:checked + label {
      border-color: var(--accent); color: var(--accent); background: var(--accent-bg);
    }

    /* MEMBERS SPLIT LIST */
    .split-list { display: flex; flex-direction: column; gap: .4rem; }

    .split-row {
      display: flex; align-items: center; gap: .85rem;
      padding: .75rem 1rem;
      background: var(--bg); border: 1px solid var(--border-lit); border-radius: 2px;
      transition: border-color .2s;
    }
    .split-row.excluded { opacity: .4; }

    .split-checkbox { display: none; }
    .split-check-box {
      width: 18px; height: 18px; border-radius: 2px; flex-shrink: 0;
      border: 1px solid var(--border-lit); background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      cursor: none; transition: border-color .2s, background .2s; font-size: .7rem;
    }
    .split-check-box.checked { border-color: var(--accent); background: var(--accent-bg); color: var(--accent); }

    .split-avatar { width: 26px; height: 26px; border-radius: 2px; overflow: hidden; background: var(--border-lit); flex-shrink: 0; }
    .split-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .split-name { flex: 1; font-size: .85rem; font-weight: 700; letter-spacing: -.01em; }
    .split-you-tag { font-family: var(--mono); font-size: .6rem; letter-spacing: .06em; text-transform: uppercase; color: var(--accent); margin-left: .4rem; }

    .split-amount-input {
      width: 90px; background: var(--surface); border: 1px solid var(--border-lit);
      color: var(--text); font-family: var(--mono); font-size: .85rem;
      padding: .4rem .6rem; border-radius: 2px; outline: none; text-align: right;
      transition: border-color .2s;
    }
    .split-amount-input:focus { border-color: var(--accent); }
    .split-amount-input:disabled { opacity: .3; cursor: not-allowed; }

    .split-equal-label {
      font-family: var(--mono); font-size: .82rem; color: var(--muted);
      min-width: 60px; text-align: right;
    }

    /* VALIDATION ROW */
    .split-validation {
      display: flex; align-items: center; justify-content: space-between;
      padding: .65rem .9rem;
      background: var(--bg); border: 1px solid var(--border-lit); border-radius: 2px;
      font-family: var(--mono); font-size: .72rem;
    }
    .split-validation-label { color: var(--muted); }
    .split-validation-val { font-weight: 500; }
    .split-validation-val.ok      { color: var(--positive); }
    .split-validation-val.over    { color: var(--danger); }
    .split-validation-val.under   { color: var(--accent); }

    /* PAID BY ROW */
    .paid-by-row {
      display: flex; align-items: center; gap: .85rem;
      padding: .85rem 1rem;
      background: var(--bg); border: 1px solid var(--border-lit); border-radius: 2px;
    }
    .paid-by-avatar { width: 28px; height: 28px; border-radius: 2px; overflow: hidden; background: var(--border-lit); flex-shrink: 0; }
    .paid-by-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .paid-by-text { font-family: var(--mono); font-size: .78rem; color: var(--muted); }
    .paid-by-text b { color: var(--text); font-weight: 400; }

    /* ACTIONS */
    .form-actions { display: flex; gap: .75rem; justify-content: flex-end; }
    .btn-primary { background: var(--accent); color: var(--bg); border: none; font-family: var(--mono); font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; padding: .65rem 1.25rem; border-radius: 2px; cursor: none; font-weight: 500; transition: background .2s, transform .1s; }
    .btn-primary:hover { background: var(--accent-dim); }
    .btn-primary:active { transform: scale(.97); }
    .btn-primary:disabled { opacity: .4; cursor: not-allowed; }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border-lit); font-family: var(--mono); font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; padding: .65rem 1.25rem; border-radius: 2px; cursor: none; transition: border-color .2s, color .2s; text-decoration: none; display: inline-block; }
    .btn-ghost:hover { border-color: var(--muted); color: var(--text); }

    .error-msg { font-family: var(--mono); font-size: .72rem; color: var(--danger); padding: .75rem 1.25rem; background: rgba(255,95,95,.06); border: 1px solid rgba(255,95,95,.15); border-radius: 2px; }

    .fade-in { opacity: 0; transform: translateY(12px); animation: fadeIn .5s forwards; animation-delay: .05s; }
    @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) {
      :root { --sidebar-w: 0px; }
      .sidebar { transform: translateX(-240px); width: 240px; transition: transform .3s ease; }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: block; }
      .content { padding: 1rem; }
      .topbar { padding: 1rem; }
    }
  </style>
</head>
<body>
<div id="cursor"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <a href="/dashboard" class="sidebar-logo">ClearTab<span>.</span></a>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Main</div>
    <a href="/dashboard" class="nav-item"><span class="nav-icon">⊞</span> Dashboard</a>
    <a href="/groups"    class="nav-item active"><span class="nav-icon">◈</span> Groups</a>
    <a href="/activity"  class="nav-item"><span class="nav-icon">◎</span> Activity</a>
    <div class="nav-section-label" style="margin-top:.5rem;">Account</div>
    <a href="/settings"    class="nav-item"><span class="nav-icon">⬡</span> Settings</a>
    <a href="/auth/logout" class="nav-item"><span class="nav-icon">→</span> Logout</a>
  </nav>
  <div class="sidebar-user">
    <div class="user-avatar">
      <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= user.userName %>" alt="<%= user.userName %>" />
    </div>
    <div class="user-info">
      <div class="user-name"><%= user.userName %></div>
      <div class="user-email"><%= user.email %></div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <button class="hamburger" id="hamburger">☰</button>
      <a href="/groups/<%= group._id %>" class="back-link">← <%= group.icon %> <%= group.name %></a>
      <span class="topbar-title">Add Expense</span>
    </div>
  </div>

  <div class="content">
    <form class="form-card fade-in" action="/groups/<%= group._id %>/expenses/new" method="POST" id="expense-form">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <!-- DETAILS -->
      <div class="card-block">
        <div class="card-block-header">Expense details</div>
        <div class="card-block-body">

          <div class="field">
            <label class="field-label" for="description">What was it for?</label>
            <input class="field-input" type="text" id="description" name="description"
              placeholder="Dinner, Petrol, Hotel…"
              value="<%= typeof description !== 'undefined' ? description : '' %>"
              required autocomplete="off" />
          </div>

          <div class="field">
            <label class="field-label" for="amount">Total amount</label>
            <div class="amount-row">
              <span class="amount-prefix">₹</span>
              <input class="field-input" type="number" id="amount" name="amount"
                placeholder="0.00" min="0.01" step="0.01"
                value="<%= typeof amount !== 'undefined' ? amount : '' %>"
                required />
            </div>
          </div>

        </div>
      </div>

      <!-- PAID BY -->
      <div class="card-block">
        <div class="card-block-header">Paid by</div>
        <div class="card-block-body">
          <div class="paid-by-row">
            <div class="paid-by-avatar">
              <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= user.userName %>" alt="<%= user.userName %>" />
            </div>
            <div class="paid-by-text">Paid by <b>You</b> (<%= user.email %>)</div>
          </div>
          <!-- hidden field — paidBy is always current user -->
          <input type="hidden" name="paidBy" value="<%= user._id %>" />
        </div>
      </div>

      <!-- SPLIT -->
      <div class="card-block">
        <div class="card-block-header">Split</div>
        <div class="card-block-body">

          <!-- SPLIT TYPE -->
          <div class="field">
            <label class="field-label">Split type</label>
            <div class="split-toggle">
              <div class="split-opt">
                <input type="radio" name="splitType" id="split-equal" value="equal" checked />
                <label for="split-equal">⊞ Equal</label>
              </div>
              <div class="split-opt">
                <input type="radio" name="splitType" id="split-exact" value="exact" />
                <label for="split-exact">◈ Exact</label>
              </div>
            </div>
          </div>

          <!-- MEMBERS -->
          <div class="split-list" id="split-list">
            <% group.members.forEach((member, i) => { %>
              <%
                const isMe = member._id.toString() === user._id.toString();
              %>
              <div class="split-row" id="split-row-<%= i %>" data-index="<%= i %>">

                <!-- checkbox (for exact — toggle inclusion) -->
                <div class="split-check-box checked" id="check-<%= i %>" data-index="<%= i %>">✓</div>

                <div class="split-avatar">
                  <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= member.userName %>" alt="<%= member.userName %>" />
                </div>

                <div class="split-name">
                  <%= isMe ? 'You' : member.userName %>
                  <% if (isMe) { %><span class="split-you-tag">you</span><% } %>
                </div>

                <!-- equal label -->
                <div class="split-equal-label" id="eq-label-<%= i %>">—</div>

                <!-- exact input (hidden by default) -->
                <input
                  class="split-amount-input"
                  type="number" min="0" step="0.01"
                  id="exact-<%= i %>"
                  name="splits[<%= i %>][amount]"
                  style="display:none;"
                  placeholder="0.00"
                />
                <input type="hidden" name="splits[<%= i %>][user]" value="<%= member._id %>" />
                <input type="hidden" name="splits[<%= i %>][included]" value="true" id="included-<%= i %>" />
              </div>
            <% }) %>
          </div>

          <!-- VALIDATION (exact only) -->
          <div class="split-validation" id="split-validation" style="display:none;">
            <span class="split-validation-label">Remaining to assign</span>
            <span class="split-validation-val" id="remaining-val">₹0</span>
          </div>

        </div>
      </div>

      <!-- ACTIONS -->
      <div class="form-actions">
        <a href="/groups/<%= group._id %>" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary" id="submit-btn">Add Expense →</button>
      </div>

    </form>
  </div>
</div>

<script>
  // cursor
  const cur = document.getElementById('cursor');
  document.addEventListener('mousemove', e => { cur.style.left = e.clientX + 'px'; cur.style.top = e.clientY + 'px'; });
  document.querySelectorAll('button, a, input, label').forEach(el => {
    el.addEventListener('mouseenter', () => { cur.style.width = '22px'; cur.style.height = '22px'; cur.style.opacity = '.5'; });
    el.addEventListener('mouseleave', () => { cur.style.width = '10px'; cur.style.height = '10px'; cur.style.opacity = '1'; });
  });
  document.getElementById('hamburger').addEventListener('click', () => { document.getElementById('sidebar').classList.toggle('open'); });

  const memberCount = <%= group.members.length %>;
  const amountInput = document.getElementById('amount');
  const submitBtn   = document.getElementById('submit-btn');
  const validation  = document.getElementById('split-validation');
  const remainingEl = document.getElementById('remaining-val');

  let splitType = 'equal';
  let included  = Array(memberCount).fill(true);

  // ── SPLIT TYPE TOGGLE ─────────────────────────────────────
  document.querySelectorAll('input[name="splitType"]').forEach(radio => {
    radio.addEventListener('change', () => {
      splitType = radio.value;
      renderSplit();
    });
  });

  // ── AMOUNT CHANGE ─────────────────────────────────────────
  amountInput.addEventListener('input', renderSplit);

  // ── CHECKBOX TOGGLE (exact mode only) ─────────────────────
  document.querySelectorAll('.split-check-box').forEach(box => {
    box.addEventListener('click', () => {
      if (splitType !== 'exact') return;
      const i = parseInt(box.dataset.index);
      included[i] = !included[i];
      document.getElementById('included-' + i).value = included[i] ? 'true' : 'false';
      renderSplit();
    });
  });

  // ── EXACT INPUT CHANGE ────────────────────────────────────
  document.querySelectorAll('.split-amount-input').forEach(inp => {
    inp.addEventListener('input', updateRemaining);
  });

  // ── RENDER ────────────────────────────────────────────────
  function renderSplit() {
    const total = parseFloat(amountInput.value) || 0;

    if (splitType === 'equal') {
      validation.style.display = 'none';
      const activeCount = included.filter(Boolean).length || memberCount;
      const share = activeCount > 0 ? (total / activeCount) : 0;

      for (let i = 0; i < memberCount; i++) {
        const eqLabel    = document.getElementById('eq-label-' + i);
        const exactInput = document.getElementById('exact-' + i);
        const checkBox   = document.getElementById('check-' + i);
        const row        = document.getElementById('split-row-' + i);

        eqLabel.style.display    = 'block';
        exactInput.style.display = 'none';
        checkBox.style.visibility = 'hidden'; // hide checkboxes in equal mode

        eqLabel.textContent = total > 0 ? '₹' + share.toFixed(2) : '—';
        row.classList.remove('excluded');

        // set hidden amount for equal
        exactInput.value = share.toFixed(2);
        document.getElementById('included-' + i).value = 'true';
      }

    } else {
      // exact mode
      validation.style.display = 'flex';

      for (let i = 0; i < memberCount; i++) {
        const eqLabel    = document.getElementById('eq-label-' + i);
        const exactInput = document.getElementById('exact-' + i);
        const checkBox   = document.getElementById('check-' + i);
        const row        = document.getElementById('split-row-' + i);

        eqLabel.style.display     = 'none';
        exactInput.style.display  = 'block';
        checkBox.style.visibility = 'visible';

        if (included[i]) {
          exactInput.disabled = false;
          row.classList.remove('excluded');
          checkBox.classList.add('checked');
          checkBox.textContent = '✓';
        } else {
          exactInput.disabled = true;
          exactInput.value    = '';
          row.classList.add('excluded');
          checkBox.classList.remove('checked');
          checkBox.textContent = '';
          document.getElementById('included-' + i).value = 'false';
        }
      }
      updateRemaining();
    }
  }

  function updateRemaining() {
    const total    = parseFloat(amountInput.value) || 0;
    let assigned   = 0;
    for (let i = 0; i < memberCount; i++) {
      if (included[i]) {
        assigned += parseFloat(document.getElementById('exact-' + i).value) || 0;
      }
    }
    const remaining = total - assigned;
    remainingEl.textContent = '₹' + Math.abs(remaining).toFixed(2);
    remainingEl.className   = 'split-validation-val ' + (Math.abs(remaining) < 0.01 ? 'ok' : remaining > 0 ? 'under' : 'over');
    submitBtn.disabled      = Math.abs(remaining) >= 0.01;
  }

  // init
  renderSplit();
</script>
</body>
</html>
