<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ClearTab — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #0a0a0a;
      --surface:     #111111;
      --surface-2:   #161616;
      --border:      #1e1e1e;
      --border-lit:  #2a2a2a;
      --text:        #e8e8e0;
      --muted:       #8b8b76;
      --muted-2:     #62625b;
      --accent:      #c8f060;
      --accent-dim:  #8faa40;
      --accent-bg:   rgba(200,240,96,.06);
      --danger:      #ff5f5f;
      --positive:    #60f0a8;
      --mono:        'DM Mono', monospace;
      --sans:        'Syne', sans-serif;
      --sidebar-w:   240px;
    }

    html { scroll-behavior: smooth; }
    a {
      cursor: none;
    }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      display: flex;
      cursor: none;
    }

    #cursor {
      position: fixed;
      width: 10px; height: 10px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%,-50%);
      transition: width .15s, height .15s, opacity .15s;
      mix-blend-mode: difference;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: .02;
      pointer-events: none;
      z-index: 0;
    }

    /* SIDEBAR */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 50;
    }
    .sidebar-logo {
      padding: 1.5rem;
      border-bottom: 1px solid var(--border);
      font-family: var(--sans);
      font-weight: 800;
      font-size: 1.1rem;
      letter-spacing: -.02em;
      color: var(--text);
      text-decoration: none;
      display: block;
    }
    .sidebar-logo span { color: var(--accent); }
    .sidebar-nav { flex: 1; padding: 1rem 0; }
    .nav-section-label {
      font-family: var(--mono);
      font-size: .62rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted-2);
      padding: .75rem 1.5rem .4rem;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .6rem 1.5rem;
      font-family: var(--mono);
      font-size: .78rem;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s, background .2s;
      position: relative;
    }
    .nav-item:hover { color: var(--text); background: var(--surface-2); }
    .nav-item.active { color: var(--accent); background: var(--accent-bg); }
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 2px;
      background: var(--accent);
    }
    .nav-icon { font-size: .9rem; width: 16px; text-align: center; flex-shrink: 0; }
    .sidebar-user {
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .user-avatar {
      width: 32px; height: 32px;
      border-radius: 2px;
      background: var(--border-lit);
      overflow: hidden;
      flex-shrink: 0;
    }
    .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .user-name {
      font-size: .8rem; font-weight: 700; letter-spacing: -.01em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .user-email {
      font-family: var(--mono); font-size: .65rem; color: var(--muted);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* MAIN */
    .main {
      margin-left: var(--sidebar-w);
      flex: 1; min-height: 100vh;
      display: flex; flex-direction: column;
      position: relative; z-index: 1;
    }

    /* TOPBAR */
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 2rem;
      border-bottom: 1px solid var(--border);
      background: rgba(10,10,10,.8);
      backdrop-filter: blur(12px);
      position: sticky; top: 0; z-index: 40;
    }
    .topbar-title { font-size: 1rem; font-weight: 700; letter-spacing: -.01em; }
    .topbar-actions { display: flex; gap: .75rem; }

    .btn-ghost {
      background: transparent; color: var(--muted);
      border: 1px solid var(--border-lit);
      font-family: var(--mono); font-size: .72rem;
      letter-spacing: .08em; text-transform: uppercase;
      padding: .55rem 1rem; border-radius: 2px;
      cursor: none; transition: border-color .2s, color .2s;
      white-space: nowrap; text-decoration: none; display: inline-block;
    }
    .btn-ghost:hover { border-color: var(--muted); color: var(--text); }

    /* CONTENT */
    .content { padding: 2rem; display: flex; flex-direction: column; gap: 2rem; }

    /* BALANCE SUMMARY */
    .balance-summary {
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); border-radius: 4px; overflow: hidden;
    }
    .balance-card { background: var(--surface); padding: 1.5rem; }
    .balance-label {
      font-family: var(--mono); font-size: .68rem;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--muted); margin-bottom: .6rem;
    }
    .balance-amount {
      font-size: 1.8rem; font-weight: 800;
      letter-spacing: -.03em; line-height: 1;
    }
    .balance-amount.owe      { color: var(--danger); }
    .balance-amount.owed     { color: var(--positive); }
    .balance-amount.net-pos  { color: var(--positive); }
    .balance-amount.net-neg  { color: var(--danger); }
    .balance-amount.net-zero { color: var(--muted); }
    .balance-sub { font-family: var(--mono); font-size: .7rem; color: var(--muted); margin-top: .4rem; }

    /* TWO COL */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start; }

    /* SECTION HEADER */
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
    .section-title  { font-size: .9rem; font-weight: 700; letter-spacing: -.01em; }
    .section-meta   { font-family: var(--mono); font-size: .7rem; color: var(--muted); }

    /* GROUPS */
    .groups-grid { display: flex; flex-direction: column; gap: .5rem; }
    .group-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 3px; padding: 1rem 1.25rem;
      display: flex; align-items: center; justify-content: space-between;
      text-decoration: none; color: var(--text);
      transition: border-color .2s, background .2s;
    }
    .group-card:hover { border-color: var(--border-lit); background: var(--surface-2); }
    .group-left { display: flex; align-items: center; gap: .85rem; }
    .group-icon {
      width: 36px; height: 36px;
      background: var(--surface-2); border: 1px solid var(--border-lit);
      border-radius: 2px; display: flex; align-items: center; justify-content: center;
      font-size: 1rem; flex-shrink: 0;
    }
    .group-name  { font-size: .88rem; font-weight: 700; letter-spacing: -.01em; margin-bottom: .15rem; }
    .group-meta  { font-family: var(--mono); font-size: .68rem; color: var(--muted); }
    .group-balance { font-family: var(--mono); font-size: .82rem; font-weight: 500; text-align: right; }
    .group-balance.owe     { color: var(--danger); }
    .group-balance.owed    { color: var(--positive); }
    .group-balance.settled { color: var(--muted); }
    .group-balance-label   { font-size: .62rem; color: var(--muted); margin-top: .15rem; text-align: right; }

    /* DEBT SIMPLIFICATION */
    .txn-list { display: flex; flex-direction: column; gap: .5rem; }

    .txn-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: .85rem;
    }
    .txn-card.i-pay     { border-left: 2px solid var(--danger);   background: var(--surface-2); }
    .txn-card.i-receive { border-left: 2px solid var(--positive); background: var(--surface-2); }

    .txn-avatar {
      width: 28px; height: 28px;
      border-radius: 2px; overflow: hidden;
      flex-shrink: 0; background: var(--border-lit);
    }
    .txn-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .txn-middle {
      flex: 1;
      display: flex;
      align-items: center;
      gap: .6rem;
      min-width: 0;
    }

    .txn-person { min-width: 0; }
    .txn-person-name {
      font-size: .82rem; font-weight: 700;
      letter-spacing: -.01em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .txn-person-name.me { color: var(--accent); }
    .txn-verb {
      font-family: var(--mono); font-size: .68rem;
      color: var(--muted); flex-shrink: 0;
      display: flex; flex-direction: column; align-items: center; gap: 2px;
    }
    .txn-verb-arrow {
      width: 28px; height: 1px;
      background: var(--border-lit);
      position: relative;
    }
    .txn-verb-arrow::after {
      content: '›';
      position: absolute; right: -5px; top: -9px;
      color: var(--muted); font-size: .85rem;
    }
    .txn-verb-label { font-size: .6rem; letter-spacing: .06em; text-transform: uppercase; }

    .txn-right { text-align: right; flex-shrink: 0; }
    .txn-figure {
      font-family: var(--mono); font-size: .88rem; font-weight: 500;
    }
    .txn-figure.i-pay-amt     { color: var(--danger); }
    .txn-figure.i-receive-amt { color: var(--positive); }
    .txn-group {
      font-family: var(--mono); font-size: .62rem;
      color: var(--muted); margin-top: .2rem;
    }

    /* EMPTY */
    .empty-state {
      background: var(--surface); border: 1px dashed var(--border-lit);
      border-radius: 3px; padding: 2.5rem 1.5rem; text-align: center;
    }
    .empty-icon  { font-size: 1.5rem; margin-bottom: .75rem; }
    .empty-title { font-size: .88rem; font-weight: 700; margin-bottom: .4rem; }
    .empty-desc  { font-family: var(--mono); font-size: .72rem; color: var(--muted); line-height: 1.6; }

    .hamburger {
      display: none; background: none; border: none;
      color: var(--text); font-size: 1.2rem; cursor: none; padding: .25rem;
    }

    /* FADE IN */
    .fade-in { opacity: 0; transform: translateY(12px); animation: fadeIn .5s forwards; }
    .fade-in:nth-child(1) { animation-delay: .05s; }
    .fade-in:nth-child(2) { animation-delay: .1s;  }
    .fade-in:nth-child(3) { animation-delay: .15s; }
    .fade-in:nth-child(4) { animation-delay: .2s;  }
    @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }

    /* RESPONSIVE */
    @media (max-width: 1024px) { .two-col { grid-template-columns: 1fr; } }
    @media (max-width: 768px) {
      :root { --sidebar-w: 0px; }
      .sidebar { transform: translateX(-240px); width: 240px; transition: transform .3s ease; }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: block; }
      .balance-summary { grid-template-columns: 1fr; }
      .content { padding: 1rem; }
      .topbar { padding: 1rem; }
    }
  </style>
</head>
<body>

<div id="cursor"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <a href="/dashboard" class="sidebar-logo">ClearTab<span>.</span></a>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Main</div>
    <a href="/dashboard" class="nav-item active"><span class="nav-icon">⊞</span> Dashboard</a>
    <a href="/groups"    class="nav-item"><span class="nav-icon">◈</span> Groups</a>
    <a href="/activity"  class="nav-item"><span class="nav-icon">◎</span> Activity</a>
    <div class="nav-section-label" style="margin-top:.5rem;">Account</div>
    <a href="/settings"    class="nav-item"><span class="nav-icon">⬡</span> Settings</a>
    <a href="/auth/logout" class="nav-item"><span class="nav-icon">→</span> Logout</a>
  </nav>
  <div class="sidebar-user">
    <div class="user-avatar">
      <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= user.userName %>" alt="<%= user.userName %>" />
    </div>
    <div class="user-info">
      <div class="user-name"><%= user.userName %></div>
      <div class="user-email"><%= user.email %></div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">

  <div class="topbar">
    <div style="display:flex;align-items:center;gap:1rem;">
      <button class="hamburger" id="hamburger" aria-label="Menu">☰</button>
      <span class="topbar-title">Dashboard</span>
    </div>
    <div class="topbar-actions">
      <a href="/groups/new" class="btn-ghost">+ New Group</a>
    </div>
  </div>

  <div class="content">

    <!-- BALANCE SUMMARY -->
    <div class="balance-summary fade-in">
      <div class="balance-card">
        <div class="balance-label">Net Balance</div>
        <div class="balance-amount <%= totalBalance > 0 ? 'net-pos' : totalBalance < 0 ? 'net-neg' : 'net-zero' %>">
          ₹<%= Math.abs(totalBalance).toLocaleString('en-IN') %>
        </div>
        <div class="balance-sub">
          <% if (totalBalance > 0) { %>overall you are owed
          <% } else if (totalBalance < 0) { %>overall you owe
          <% } else { %>you are all settled up<% } %>
        </div>
      </div>
      <div class="balance-card">
        <div class="balance-label">You Owe</div>
        <div class="balance-amount owe">₹<%= totalOwe.toLocaleString('en-IN') %></div>
        <div class="balance-sub"><%= oweCount %> pending payment<%= oweCount !== 1 ? 's' : '' %></div>
      </div>
      <div class="balance-card">
        <div class="balance-label">You Are Owed</div>
        <div class="balance-amount owed">₹<%= totalOwed.toLocaleString('en-IN') %></div>
        <div class="balance-sub"><%= owedCount %> pending receipt<%= owedCount !== 1 ? 's' : '' %></div>
      </div>
    </div>

    <!-- TWO COL -->
    <div class="two-col">

      <!-- LEFT: GROUPS -->
      <div class="fade-in">
        <div class="section-header">
          <div class="section-title">Your Groups</div>
          <div class="section-meta"><%= groups.length %> total</div>
        </div>

        <% if (groups.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">◈</div>
            <div class="empty-title">No groups yet</div>
            <p class="empty-desc">Create a group to start splitting.<br>Expenses can only be added inside a group.</p>
          </div>
        <% } else { %>
          <div class="groups-grid">
            <% groups.forEach(group => { %>
              <a href="/groups/<%= group._id %>" class="group-card">
                <div class="group-left">
                  <div class="group-icon"><%= group.icon || '◈' %></div>
                  <div>
                    <div class="group-name"><%= group.name %></div>
                    <div class="group-meta">
                      <%= group.members.length %> member<%= group.members.length !== 1 ? 's' : '' %> ·
                      <%= group.expenseCount %> expense<%= group.expenseCount !== 1 ? 's' : '' %>
                    </div>
                  </div>
                </div>
                <div>
                  <% if (group.userBalance === 0) { %>
                    <div class="group-balance settled">Settled</div>
                  <% } else if (group.userBalance < 0) { %>
                    <div class="group-balance owe">₹<%= Math.abs(group.userBalance).toLocaleString('en-IN') %></div>
                    <div class="group-balance-label">you owe</div>
                  <% } else { %>
                    <div class="group-balance owed">₹<%= group.userBalance.toLocaleString('en-IN') %></div>
                    <div class="group-balance-label">you're owed</div>
                  <% } %>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- RIGHT: SUGGESTED PAYMENTS (debt simplification) -->
      <div class="fade-in">
        <div class="section-header">
          <div class="section-title">Suggested Payments</div>
          <div class="section-meta">
            <% if (transactions.length > 0) { %>
              <%= transactions.length %> txn<%= transactions.length !== 1 ? 's' : '' %> clears everything
            <% } %>
          </div>
        </div>

        <% if (transactions.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">✦</div>
            <div class="empty-title">All settled up</div>
            <p class="empty-desc">No pending payments across<br>any of your groups.</p>
          </div>
        <% } else { %>
          <div class="txn-list">
            <% transactions.forEach(txn => { %>
              <%
                const iPay     = txn.from._id.toString() === user._id.toString();
                const iReceive = txn.to._id.toString()   === user._id.toString();
              %>
              <div class="txn-card <%= iPay ? 'i-pay' : iReceive ? 'i-receive' : '' %>">

                <div class="txn-avatar">
                  <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= txn.from.userName %>" alt="<%= txn.from.userName %>" />
                </div>

                <div class="txn-middle">
                  <div class="txn-person">
                    <div class="txn-person-name <%= iPay ? 'me' : '' %>">
                      <%= iPay ? 'You' : txn.from.userName %>
                    </div>
                  </div>

                  <div class="txn-verb">
                    <div class="txn-verb-arrow"></div>
                    <div class="txn-verb-label">pays</div>
                  </div>

                  <div class="txn-person">
                    <div class="txn-person-name <%= iReceive ? 'me' : '' %>">
                      <%= iReceive ? 'You' : txn.to.userName %>
                    </div>
                  </div>
                </div>

                <div class="txn-right">
                  <div class="txn-figure <%= iPay ? 'i-pay-amt' : iReceive ? 'i-receive-amt' : '' %>">
                    ₹<%= txn.amount.toLocaleString('en-IN') %>
                  </div>
                  <div class="txn-group"><%= txn.groupName %></div>
                </div>

              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<script>
  const cur = document.getElementById('cursor');
  document.addEventListener('mousemove', e => {
    cur.style.left = e.clientX + 'px';
    cur.style.top  = e.clientY + 'px';
  });
  document.querySelectorAll('button, a, input').forEach(el => {
    el.addEventListener('mouseenter', () => { cur.style.width = '22px'; cur.style.height = '22px'; cur.style.opacity = '.5'; });
    el.addEventListener('mouseleave', () => { cur.style.width = '10px'; cur.style.height = '10px'; cur.style.opacity = '1'; });
  });
  document.getElementById('hamburger').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('open');
  });
</script>
</body>
</html>
